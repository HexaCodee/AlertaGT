PORT=0000

URI_MONGODB=mongodb://example-host:27017/example_database
JWT_SECRET=example_jwt_secret_replace_in_production
JWT_ISSUER=example_issuer
JWT_AUDIENCE=example_audience
JWT_EXPIRES_IN=1h

CLOUDINARY_CLOUD_NAME=example_cloud_name
CLOUDINARY_API_KEY=example_api_key
CLOUDINARY_API_SECRET=example_api_secret
CLOUDINARY_FOLDER=example_folder

# Servicio de Auth para validación de tokens
AUTH_SERVICE_URL=http://example-auth-service/api/v1

# URLs de otros servicios
GEO_SERVICE_URL=http://example-geo-service/api/v1
NOTIFICATIONS_SERVICE_URL=http://example-notifications-service/api/v1

# Token compartido entre microservicios
SERVICE_TOKEN=example_service_token_replace_me