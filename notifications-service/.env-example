PORT=3001
MONGODB_URI=mongodb://example-host:27017/example_notifications_db
CORS_ORIGIN=http://example-client.com

# Firebase Configuration
FIREBASE_SERVICE_ACCOUNT_PATH=./path-to-example-firebase-service-account.json

# Servicio de Auth para validación de tokens
AUTH_SERVICE_URL=http://example-auth-service/api/v1

# Service token shared between backend services
SERVICE_TOKEN=example_shared_service_token_replace_in_production