PORT=3002
MONGODB_URI=mongodb://example-host:27017/example_geolocatedalerts_db
CORS_ORIGIN=http://example-client.com

# Servicio de Auth para validación de tokens
AUTH_SERVICE_URL=http://example-auth-service/api/v1

# Servicio de Posts para obtener lugares
POSTS_SERVICE_URL=http://example-posts-service/api/v1

# Servicio de Notificaciones
NOTIFICATIONS_SERVICE_URL=http://example-notifications-service/api/v1

# Service token shared between backend services
SERVICE_TOKEN=example_shared_token_replace_in_production