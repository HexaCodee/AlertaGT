{
  "ConnectionStrings": {
    "DefaultConnection": "mongodb://example-host:27017",
    "MongoDbDatabase": "example_auth_db"
  },
  "CloudinarySettings": {
    "CloudName": "example_cloud_name",
    "ApiKey": "example_api_key",
    "ApiSecret": "example_api_secret",
    "BaseUrl": "https://res.cloudinary.com/example_cloud/image/upload/",
    "Folder": "example_app/profiles",
    "DefaultAvatarPath": "default_avatar.png"
  },
  "SmtpSettings": {
    "Host": "smtp.example.com",
    "Port": "587",
    "EnableSsl": true,
    "Username": "example@email.com",
    "Password": "example_password",
    "FromEmail": "noreply@example.com",
    "FromName": "Example Support",
    "Enabled": false,
    "Timeout": 10000,
    "UseFallback": false,
    "UseImplicitSsl": false,
    "IgnoreCertificateErrors": false
  },

  "JwtSettings": {
    "SecretKey": "example_super_secret_key_replace_in_production",
    "Issuer": "ExampleApp",
    "Audience": "ExampleAppUsers",
    "ExpirationMinutes": 60
  },

  "AppSettings": {
    "FrontendUrl": "http://example-frontend.com"
  },

  "Security": {
    "AllowedOrigins": [
      "http://example-frontend.com"
    ],
    "AdminAllowedOrigins": [
      "http://example-admin.com"
    ],
    "BlacklistedIPs": [],
    "WhitelistedIPs": [],
    "RestrictedPaths": []
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/app-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },

  "AllowedHosts": "*"
}